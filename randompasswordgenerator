
import string
import secrets   
import math


def get_password_length():
    """Phase 1: Input - capture and validate the target integer."""
    while True:
        try:
            length = int(input("Enter desired password length (min 8, recommended 16+): "))

            if length < 8:
                print("⚠ For security, minimum length is 8 characters. Try again.\n")
                continue
            if length > 128:
                print("⚠ Maximum supported length is 128 characters. Try again.\n")
                continue

            return length

        except ValueError:
            print("⚠ Invalid input. Please enter a whole number.\n")


def generate_password(length):
    """Phase 2: Process - build the character pool and select randomly."""

    # Standardized character classification via the string module
    letters = string.ascii_letters      # a-z + A-Z
    digits = string.digits              # 0-9
    symbols = string.punctuation        # !@#$%^&* etc.

    # Combine into one pool
    character_pool = letters + digits + symbols

    # Enterprise approach: build a list, then .join() -> O(N), not O(N^2)
    password_chars = [secrets.choice(character_pool) for _ in range(length)]

    # Guarantee at least one of each type (common real-world requirement)
    password_chars[0] = secrets.choice(letters)
    password_chars[1] = secrets.choice(digits)
    password_chars[2] = secrets.choice(symbols)

    # Shuffle so the guaranteed characters aren't always in the same position
    secrets.SystemRandom().shuffle(password_chars)

    return ''.join(password_chars)


def calculate_entropy(length, pool_size=94):
    """Phase 3: Output - mathematically prove password strength.
    E = L * log2(R)
    """
    entropy = length * math.log2(pool_size)
    return entropy


def rate_strength(entropy_bits):
    if entropy_bits < 40:
        return "Weak"
    elif entropy_bits < 60:
        return "Moderate"
    elif entropy_bits < 80:
        return "Strong"
    else:
        return "Very Strong"


def main():
    print("=== DecodeLabs Secure Password Generator ===\n")

    length = get_password_length()
    password = generate_password(length)
    entropy = calculate_entropy(length)
    strength = rate_strength(entropy)

    print("\n=== Result ===")
    print(f"Generated Password : {password}")
    print(f"Length              : {length} characters")
    print(f"Entropy             : {entropy:.2f} bits")
    print(f"Strength Rating     : {strength}")


if __name__ == "__main__":
    main()